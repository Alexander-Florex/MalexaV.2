    "mysql2": "^3.10.0",
    "sequelize": "^6.37.3",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
